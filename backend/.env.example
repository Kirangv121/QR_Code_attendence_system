PORT=5000
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/attendanceDB?retryWrites=true&w=majority
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d
QR_EXPIRY_MINUTES=5

# Comma-separated allowed browser origins (your Vercel URL after first deploy)
FRONTEND_ORIGIN=http://localhost:5173,https://your-app.vercel.app

# Optional — Node generates QR on Vercel; set only if you host python-service on Railway
# PYTHON_QR_SERVICE_URL=https://your-service.up.railway.app
